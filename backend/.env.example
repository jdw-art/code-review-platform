AI_CODE_REVIEWER_APP_NAME="AI Code Reviewer"
AI_CODE_REVIEWER_API_PREFIX="/api/v1"
AI_CODE_REVIEWER_POSTGRES_HOST="localhost"
AI_CODE_REVIEWER_POSTGRES_PORT=5432
AI_CODE_REVIEWER_POSTGRES_DB="ai_code_reviewer"
AI_CODE_REVIEWER_POSTGRES_USER="postgres"
AI_CODE_REVIEWER_POSTGRES_PASSWORD="postgres"
AI_CODE_REVIEWER_REDIS_HOST="localhost"
AI_CODE_REVIEWER_REDIS_PORT=6379
AI_CODE_REVIEWER_REDIS_DB=0
# Bootstrap-only defaults. Override these outside local development.
AI_CODE_REVIEWER_JWT_SECRET_KEY="change-me-in-env"
AI_CODE_REVIEWER_ACCESS_TOKEN_TTL_MINUTES=15
AI_CODE_REVIEWER_REFRESH_TOKEN_TTL_DAYS=7
AI_CODE_REVIEWER_BOOTSTRAP_ADMIN_USERNAME="username"
AI_CODE_REVIEWER_BOOTSTRAP_ADMIN_PASSWORD="password"

# Webhook defaults
AI_CODE_REVIEWER_REVIEW_QUEUE_NAME="review:jobs"
AI_CODE_REVIEWER_REVIEW_LOCK_PREFIX="review:lock"
AI_CODE_REVIEWER_REVIEW_MAX_RETRIES=3
AI_CODE_REVIEWER_REVIEW_LOCK_TTL_SECONDS=1800
AI_CODE_REVIEWER_REPORT_CRONTAB_EXPRESSION="0 18 * * 1-5"

GITLAB_URL="https://gitlab.example.com"
GITLAB_ACCESS_TOKEN="xxx"
GITHUB_URL="https://github.com"
GITHUB_API_URL="https://api.github.com"
GITHUB_ACCESS_TOKEN="token"

#大模型供应商配置,支持 deepseek, openai, zhipuai, qwen, ollama 和 anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=api-key
OPENAI_API_BASE_URL=https://xxx/v1
OPENAI_API_MODEL=gpt-5.4

#支持review的文件类型
SUPPORTED_EXTENSIONS=.c,.cc,.cpp,.cs,.css,.cxx,.go,.h,.hh,.hpp,.hxx,.java,.js,.jsx,.md,.php,.py,.sql,.ts,.tsx,.vue,.yml
#每次 Review 的最大 Token 限制（超出部分自动截断）
REVIEW_MAX_TOKENS=10000
#Review 风格选项：professional（专业） | sarcastic（毒舌） | gentle（温和） | humorous（幽默）
REVIEW_STYLE=professional
PUSH_REVIEW_ENABLED=1
MERGE_REVIEW_ONLY_PROTECTED_BRANCHES_ENABLED=0
REPORT_CRONTAB_EXPRESSION="0 18 * * 1-5"